# lgrep Configuration

# Required: Voyage AI API Key
# Get one at https://dash.voyageai.com/
VOYAGE_API_KEY=your_api_key_here

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
# Default: INFO
LGREP_LOG_LEVEL=INFO

# Optional: Directory for LanceDB vector databases
# Default: ~/.cache/lgrep
# LGREP_CACHE_DIR=/path/to/custom/cache

# Optional: Colon-separated project paths to warm on server startup
# Default: none
# LGREP_WARM_PATHS=/path/to/project-a:/path/to/project-b

# Optional: Auto-start file watchers for warmed projects
# Default: false
# LGREP_AUTO_WATCH=true

# Optional: Per-tool server-side timeout in seconds
# Bounds each MCP tool invocation so slow projects or Voyage API hiccups
# do not stall the session. Increase if your indexer routinely exceeds 45s.
# Default: 45
# LGREP_TOOL_TIMEOUT_S=45
